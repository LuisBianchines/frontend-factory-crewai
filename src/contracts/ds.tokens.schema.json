{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignTokens",
  "type": "object",
  "required": ["themeName", "colors", "typography", "radii", "shadows", "spacing"],
  "properties": {
    "themeName": { "type": "string" },
    "colors": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "typography": {
      "type": "object",
      "required": ["fontFamily", "headings", "body"],
      "properties": {
        "fontFamily": { "type": "string" },
        "headings": { "type": "string" },
        "body": { "type": "string" }
      }
    },
    "radii": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "shadows": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "spacing": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
